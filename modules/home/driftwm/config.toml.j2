mod_key = "super"
autostart = [
{% for cmd in extracmds %}
  "{{ cmd }}",
{% endfor %}
  "while true; do noctalia-shell; sleep 1; done"
]
window_placement = "auto"

[env]
"_JAVA_AWT_WM_NONREPARENTING" = "1"
"QT_QPA_PLATFORM" = "wayland;xcb"

[input.keyboard]
layout = "pl"
num_lock = true

[input.mouse]
accel_speed = 0.1
accel_profile = "adaptive"

[input.trackpad]
accel_speed = 0.1
click_method = "button_areas"

[cursor]
inactive_opacity = 0.25

[mouse.on-canvas]
"right" = "spawn noctalia-shell ipc call launcher toggle"

[mouse.anywhere]
"ctrl+trackpad-scroll" = "pan-viewport"
"ctrl+left" = "pan-viewport"

[gestures]
swipe_threshold = 6

[gestures.on-window]
"3-finger-doubletap-swipe" = "none"
"alt+3-finger-doubletap-swipe" = "move-window"
"ctrl+alt+3-finger-doubletap-swipe" = "resize-window"
"ctrl+2-finger-pinch-in" = "zoom-in"
"ctrl+2-finger-pinch-out" = "zoom-out"

[navigation.edge_pan]
zone = 60.0
cursor_zone = 10.0
speed_min = 1.0
speed_max = 6.0
cursor_pan = false

[snap]
enabled = true
gap = 8
distance = 20
centers = true
corners = true

[zoom]
trackpad_speed = 1.2

[background]
type = "shader"
path = "~/.config/driftwm/background.glsl"
animate_fps = 24

[decorations]
title_bar_height = 30
bg_color = "#{{ base00 }}"
fg_color = "#{{ base05 }}"
corner_radius = 10
border_width = 2
border_color = "#{{ base02 }}"
border_color_focused = "#{{ base0E }}"
shadow = true
font = "{{ font }}"

[output.outline]
color = "#{{ base0E }}"
thickness = 2

[xwayland]
enabled = true
path = "{{ xwayland_satellite_path }}"

[keybindings]
"mod+tab" = "toggle-cursor-pan"
"mod+space" = "spawn noctalia-shell ipc call launcher toggle"
"mod+return" = "spawn noctalia-shell ipc call launcher toggle"
"ctrl+alt+t" = "exec kitty"
"XF86Calculator" = "exec qalculate-qt"
"XF86Search" = "exec brave"
"XF86WWW" = "exec brave"
"XF86Mail" = "exec brave https://mail.google.com"
"alt+f4" = "close-window"
"XF86AudioRaiseVolume" = "spawn pamixer -i 5"
"XF86AudioLowerVolume" = "spawn pamixer -d 5"
"XF86AudioMute" = "spawn pamixer -t"
"mod+equal" = "zoom-in"
"mod+minus" = "zoom-out"
"mod+up" = "center-nearest up"
"mod+down" = "center-nearest down"
"mod+left" = "center-nearest left"
"mod+right" = "center-nearest right"
"mod+q" = "close-window"
"mod+e" = "exec dolphin"
"mod+w" = "pan-viewport up"
"mod+s" = "pan-viewport down"
"mod+a" = "pan-viewport left"
"mod+d" = "pan-viewport right"
"mod+n" = "spawn noctalia-shell ipc call notifications toggleHistory"
"mod+v" = "spawn noctalia-shell ipc call launcher clipboard"
"mod+." = "spawn noctalia-shell ipc call launcher emoji"
"mod+escape" = "spawn noctalia-shell ipc call sessionMenu toggle"
"mod+f11" = "spawn noctalia-shell ipc call bar toggle"
"mod+l" = "spawn noctalia-shell ipc call lockScreen lock"
"mod+r" = "spawn noctalia-shell ipc call controlCenter toggle"

# Cosmic settings: hide winit window helper and apply fixed window size
[[window_rules]]
title = "winit window"
widget = true

[[window_rules]]
app_id = "Waydroid"
decoration = "server"

[[window_rules]]
app_id = "waydroid.*"
decoration = "server"

