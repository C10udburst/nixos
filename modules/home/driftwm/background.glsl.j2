// Memphis/boho abstract — rose pine dawn pastel composition via FBM blobs.
precision highp float;

varying vec2 v_coords;
uniform vec2 size;
uniform vec2 u_camera;
uniform float u_time;

float hash1(vec2 p) {
    return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
}

float noise(vec2 p) {
    vec2 i = floor(p);
    vec2 f = fract(p);
    f = f * f * (3.0 - 2.0 * f);
    float a = hash1(i);
    float b = hash1(i + vec2(1.0, 0.0));
    float c = hash1(i + vec2(0.0, 1.0));
    float d = hash1(i + vec2(1.0, 1.0));
    return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
}

float fbm(vec2 p, float t) {
    float v = 0.0;
    float a = 0.5;
    mat2 rot = mat2(0.8, 0.6, -0.6, 0.8);
    for (int i = 0; i < 4; i++) {
        // Slow time-based offset for morphing in place
        vec2 offset = vec2(sin(t * 0.3), cos(t * 0.24)) * 0.03 * float(i + 1);
        v += a * noise(p + offset);
        p = rot * p * 2.0;
        a *= 0.5;
    }
    return v;
}

// Pre-mixed with base so blobs read as subtle dark washes, not full saturation.
const vec3 BASE = {{ to_rgb_vec3(base00) }};
const vec3 MAUVE = {{ to_rgb_vec3(base02) }};
const vec3 BLUE = {{ to_rgb_vec3(base03) }};
const vec3 TEAL = {{ to_rgb_vec3(base04) }};
const vec3 LAVENDER = {{ to_rgb_vec3(base0A) }};
const vec3 PEACH = {{ to_rgb_vec3(base0B) }};

vec3 wash(vec3 c, float amount) {
    return mix(c, BASE, amount);
}

vec3 paletteColor(float t) {
    // Pure step() = pixel-hard "cut-paper" Memphis edges, no antialiasing.
    vec3 col = BASE;
    col = mix(col, wash(MAUVE, 0.65), step(0.390, t));
    col = mix(col, wash(BLUE, 0.65), step(0.525, t));
    col = mix(col, wash(TEAL, 0.65), step(0.620, t));
    col = mix(col, wash(LAVENDER, 0.70), step(0.695, t));
    col = mix(col, wash(PEACH, 0.70), step(0.770, t));
    return col;
}

void main() {
    vec2 canvas = (v_coords * size + u_camera) * 0.0022;
    float f = fbm(canvas, u_time);
    vec3 col = paletteColor(f);
    gl_FragColor = vec4(col, 1.0);
}
