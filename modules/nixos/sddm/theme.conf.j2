[General]
# General appearance
Background="{{ background_image }}"
DimBackgroundImage="0.05"
ScaleImage="Crop"
ScreenWidth=1920
ScreenHeight=1080

# Form position: left, right or center
FormPosition="center"

# Fonts & Sizes
InterfaceScale=1
FontSize=10
Font="{{ font }}"

# Colors
MainColor="#{{ base0E }}"
AccentColor="#{{ base05 }}"
BackgroundColor="#{{ base00 }}"

# Settings
ForceShortcutType="true"
ForcePasswordType="true"
ForceHideInterface="false"

# Cursor
CursorTheme="Breeze"
